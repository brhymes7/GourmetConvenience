# Copy this file to server/.env for local development.
# Never commit real Clover tokens to GitHub.

# App
NODE_ENV=development
PORT=5001
APP_BASE_URL=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
ADMIN_API_KEY=change-this-before-production
ADMIN_PASSWORD=change-this-before-production
ADMIN_TOKEN_SECRET=change-this-before-production

# Clover
# Use sandbox until the entire flow is tested.
CLOVER_ENV=sandbox
CLOVER_MERCHANT_ID=your_test_or_live_merchant_id
CLOVER_PRIVATE_TOKEN=your_private_ecommerce_token_or_oauth_access_token
CLOVER_PAGE_CONFIG_UUID=
CLOVER_WEBHOOK_SIGNING_SECRET=your_webhook_signing_secret

# Optional tax setting. Keep 0 until you configure your tax rules.
DEFAULT_TAX_RATE_BPS=0
